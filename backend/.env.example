# ============================================================
# ZROXZ BACKEND — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Live secrets go in Render → Environment tab.
# ============================================================

PORT=4000
NODE_ENV=development

# Supabase — use the SERVICE ROLE key (bypasses RLS, server-only)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxx

# OpenAI — set a hard spend limit at platform.openai.com → Billing → Limits
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# Resend — free tier, 100 emails/day. Verify your domain first.
RESEND_API_KEY=re_xxxxxxxxxxxx

# The email address that receives new lead notifications
CONTACT_EMAIL_TO=hello@zroxz.com

# CORS — only allow requests from your frontend domain
CORS_ORIGIN=https://zroxz.com

# Admin auth — generate hash once:
# node -e "import('bcryptjs').then(b => console.log(b.default.hashSync('your-password', 10)))"
ADMIN_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxx
